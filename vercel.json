{
    "builds": [
        {
            "src": "app.py",
            "use": "@vercel/python"
        }
    ],
    "functions": {
        "api/yt-proxy.js": {
            "runtime": "edge"
        }
    },
    "routes": [
        {
            "src": "/api/yt-proxy",
            "dest": "/api/yt-proxy.js"
        },
        {
            "src": "/(.*)",
            "dest": "/app.py"
        }
    ]
}
